# ---------- Stone & Design Board environment ----------
#
# Copy this file to `.env.local` (for the Next.js app) and fill in real values.
# Values marked "server-only" must NEVER be exposed to the client — keep them
# out of any NEXT_PUBLIC_* variable.
#
# After creating a hosted Supabase project at https://supabase.com/dashboard,
# find these values under: Project Settings → API, and Project Settings →
# Database (for the connection string).

# --- Public (bundled into the client) ---

# The full URL of your Supabase project, e.g. https://abcdefg.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key. Safe to expose to the browser; RLS policies
# gate what it can actually read/write.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Absolute URL where this Next.js app is served. Used to build OAuth redirect
# URLs and invite links. In dev: http://localhost:3000. In production: your
# Vercel domain (e.g. https://stone-design-board.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only ---

# Supabase service role key. Bypasses RLS — used ONLY by the seed script and
# by any future server-only jobs (cron, webhooks). Never import this into
# client code or a server action the user can invoke.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Prisma (`prisma db pull`, `prisma generate`,
# seed script). Get it from Supabase → Project Settings → Database →
# "Connection string" → "URI". Use the pooler URL (port 6543) for runtime
# and the direct URL (port 5432) for migrations.
DATABASE_URL=

# Optional: direct (non-pooled) connection used by prisma migrate if you ever
# fall back to Prisma-driven migrations. Leave blank if using Supabase CLI.
DIRECT_URL=

# Optional: your Supabase project ref (the subdomain portion of
# NEXT_PUBLIC_SUPABASE_URL). Used by `supabase link` so the CLI can push
# migrations to the hosted project.
SUPABASE_PROJECT_REF=
